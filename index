        this.vx = (Math.random() - 0.5) * 0.32;
        this.vy = (Math.random() - 0.5) * 0.32;
        this.size = Math.random() * 1.4 + 0.3;
        this.alpha = Math.random() * 0.30 + 0.06;
        // 60% silver, 40% gold
        this.type = Math.random() > 0.4 ? 'silver' : 'gold';
        this.life = 1;
        this.decay = Math.random() * 0.0018 + 0.0007;
      }
      update() {
        this.x += this.vx;
        this.y += this.vy;
        this.life -= this.decay;
        if (this.life <= 0 || this.x < 0 || this.x > canvas.width || this.y < 0 || this.y > canvas.height) this.reset();
      }
      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
        ctx.fillStyle = this.type === 'gold'
