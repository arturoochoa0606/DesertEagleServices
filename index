      </div>`;
    chatContainer.appendChild(typingDiv);

    // Initial message
    addMessage('Bienvenido a <span style="color:#D0D0D0;font-weight:600">Desert Eagle</span>. Soy tu asistente holográfico de IA. ¿En qué puedo ayudarte hoy? Usa los atajos de la izquierda para probar mis capacidades.');

    function sendMessage() {
      const text = demoInput.value.trim();
      if (!text || isWaiting) return;

      addMessage(text, true);
      demoInput.value = '';
      isWaiting = true;
      sendBtn.disabled = true;
      sendBtn.textContent = '...';
      chatStatus.textContent = '● Procesando con IA...';
      chatStatus.style.color = '#D4AF37';

      typingDiv.style.display = 'flex';
      chatContainer.scrollTop = chatContainer.scrollHeight;

      setTimeout(() => {
        typingDiv.style.display = 'none';
        addMessage(getResponse(text));
        isWaiting = false;
        sendBtn.disabled = false;
        sendBtn.textContent = 'ENVIAR';
        chatStatus.textContent = '● Online — Respondiendo';
        chatStatus.style.color = '#4ade80';
      }, 1600 + Math.random() * 900);
    }

    sendBtn.addEventListener('click', sendMessage);
    demoInput.addEventListener('keydown', e => { if (e.key === 'Enter' && !e.shiftKey) sendMessage(); });
    document.querySelectorAll('.quick-reply').forEach(btn => {
      btn.addEventListener('click', () => { demoInput.value = btn.textContent; sendMessage(); });
    });
    document.getElementById('clear-chat').addEventListener('click', () => {
      chatContainer.querySelectorAll('.flex:not(#typing-indicator)').forEach(m => m.remove());
      addMessage('Chat limpiado. <span style="color:#D0D0D0">Eagle IA</span> listo para una nueva consulta.');
      showToast('Chat limpiado correctamente', 'success');
    });

    // ── Service Modal ────────────────────────────────────
    const modal       = document.getElementById('service-modal');
    const modalIcon   = document.getElementById('modal-icon');
    const modalTag    = document.getElementById('modal-tag');
    const modalTitle  = document.getElementById('modal-title');
    const modalDesc   = document.getElementById('modal-desc');
    const modalFeat   = document.getElementById('modal-features');
    const modalTags   = document.getElementById('modal-tags');

    function openModal(key) {
      const s = SERVICES[key]; if (!s) return;
      modalIcon.innerHTML  = s.icon;
      modalTag.textContent  = s.tag;
      modalTitle.textContent = s.title;
      modalDesc.textContent  = s.desc;
      modalFeat.innerHTML  = s.features.map(f =>
        `<div class="flex items-start gap-2 text-sm font-rajdhani text-gray-300">
          <span style="color:#D4AF37;flex-shrink:0;margin-top:2px">▸</span>${f}
        </div>`).join('');
      modalTags.innerHTML  = s.tags.map(t => `<span class="tech-tag">${t}</span>`).join('');
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    }
    function closeModal() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.open-service-modal').forEach(btn => {
      btn.addEventListener('click', () => openModal(btn.getAttribute('data-service')));
    });
    document.getElementById('modal-close').addEventListener('click', closeModal);
    document.getElementById('modal-close-2').addEventListener('click', closeModal);
    document.querySelectorAll('.modal-cta-btn').forEach(btn => {
      btn.addEventListener('click', () => { closeModal(); setTimeout(() => scrollToTarget('#contacto'), 300); });
    });
    modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    // ── Contact Form ─────────────────────────────────────
    const contactForm = document.getElementById('contact-form');
    const contactBtn  = document.getElementById('contact-btn');

    function setFieldError(id, has) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('error-field', has);
    }
    function validEmail(e) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e); }

    contactForm.addEventListener('submit', e => {
      e.preventDefault();
      const name    = document.getElementById('field-name').value.trim();
      const email   = document.getElementById('field-email').value.trim();
      const service = document.getElementById('field-service').value;
      const message = document.getElementById('field-message').value.trim();

      ['field-name','field-email','field-service','field-message'].forEach(id => setFieldError(id, false));

      let hasErrors = false;
      if (!name)                  { setFieldError('field-name', true);    hasErrors = true; }
      if (!email||!validEmail(email)){ setFieldError('field-email', true); hasErrors = true; }
      if (!service)               { setFieldError('field-service', true); hasErrors = true; }
      if (!message||message.length<10){ setFieldError('field-message', true); hasErrors = true; }

      if (hasErrors) { showToast('Por favor completa todos los campos requeridos.', 'error'); return; }

      contactBtn.disabled = true;
      contactBtn.textContent = 'ENVIANDO...';
      contactBtn.style.background = 'linear-gradient(135deg,#5a4800,#3d3000)';

      setTimeout(() => {
        contactBtn.textContent = '✓ MISIÓN ACTIVADA';
        contactBtn.style.background = 'linear-gradient(135deg,#065f46,#047857)';
        showToast('¡Mensaje enviado! Te contactaremos en menos de 24h.', 'success');
        setTimeout(() => {
          contactForm.reset();
          contactBtn.disabled = false;
          contactBtn.textContent = 'ACTIVAR EAGLE IA';
          contactBtn.style.background = '';
        }, 4000);
      }, 1800);
    });

    // ── Active Nav Highlight ─────────────────────────────
    const sections = document.querySelectorAll('section[id]');
    const navLinks  = document.querySelectorAll('.nav-blur a.nav-link[href^="#"]');
    new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = '#' + entry.target.getAttribute('id');
          navLinks.forEach(a => {
            a.style.color = a.getAttribute('href') === id ? '#D4AF37' : '';
          });
        }
      });
    }, { threshold: 0.4 }).observe || sections.forEach(s => {
      // fallback observe
    });
    const sectionObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = '#' + entry.target.getAttribute('id');
          navLinks.forEach(a => {
            a.style.color = a.getAttribute('href') === id ? '#D4AF37' : '';
          });
        }
      });
    }, { threshold: 0.4 });
    sections.forEach(s => sectionObs.observe(s));

  }); // end DOMContentLoaded
  </script>
  <script>window.onload=function(){var d=document.createElement("div");d.id="appLoadFinished";document.body.appendChild(d);};</script>


</body></html>
